# MONGODB_URI: Connection string for MongoDB (MERN stack)
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/hospital"

# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls. 
# Supports standard DeepSeek (baseURL: api.deepseek.com) 
# and NVIDIA NIM (baseURL: integrate.api.nvidia.com if key starts with nvapi-)
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_OR_NVIDIA_API_KEY"

# KIMI_API_KEY: Required for Kimi AI (Moonshot AI) API calls.
KIMI_API_KEY="MY_KIMI_API_KEY"
VITE_KIMI_API_KEY="MY_KIMI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AMap (Gaode Maps) API Key
VITE_AMAP_KEY="YOUR_AMAP_KEY_HERE"
VITE_AMAP_SECURITY_JS_CODE="YOUR_AMAP_SECURITY_JS_CODE_HERE"
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# Cloudinary: Required for document storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
